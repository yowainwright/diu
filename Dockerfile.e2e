FROM golang:1.25-alpine

WORKDIR /app

RUN apk add --no-cache bash zsh ca-certificates

COPY go.mod go.sum ./
RUN go mod download

COPY . .

RUN CGO_ENABLED=0 go build -buildvcs=false -o /usr/local/bin/diu ./cmd/diu

ENV DIU_E2E_DOCKER=1
ENV GOFLAGS=-mod=readonly

CMD ["go", "test", "-count=1", "-tags=e2e", "-v", "./e2e/..."]
